    <item>
      <title>Research</title>
      <link>http://localhost:1313/research/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/research/</guid>
      <description>&lt;div class=&#34;research-overview&#34;&gt;&#xA;  &lt;div class=&#34;overview-card&#34;&gt;&#xA;    &lt;h3&gt;Research Interests&lt;/h3&gt;&#xA;    &lt;ul&gt;&#xA;      &lt;li&gt;Biomimetic robotics&lt;/li&gt;&#xA;      &lt;li&gt;Collective intelligence&lt;/li&gt;&#xA;      &lt;li&gt;Physical AI&lt;/li&gt;&#xA;    &lt;/ul&gt;&#xA;  &lt;/div&gt;&#xA;  &lt;div class=&#34;overview-card&#34;&gt;&#xA;    &lt;h3&gt;Methods&lt;/h3&gt;&#xA;    &lt;ul&gt;&#xA;      &lt;li&gt;Non-equilibrium statistical mechanics&lt;/li&gt;&#xA;      &lt;li&gt;Stochastic processes&lt;/li&gt;&#xA;      &lt;li&gt;Embodied AI &amp; swarm intelligence&lt;/li&gt;&#xA;    &lt;/ul&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&lt;h2 id=&#34;recent-projects&#34;&gt;Recent Projects&lt;/h2&gt;&#xA;&lt;div class=&#34;project-card&#34;&gt;&#xA;  &lt;div class=&#34;project-info&#34;&gt;&#xA;    &lt;h3&gt;Social Robots&lt;/h3&gt;&#xA;    &lt;p&gt;The goal of this project is to design robots that interact with each other, with animals, and with humans. Rather than programming fixed outcomes, this project harnesses &lt;b&gt;emergence&lt;/b&gt; as a generative principle, engineering local interaction rules that give rise to &lt;i&gt;interesting, remarkable, and unusual&lt;/i&gt; (Olkowski, 2011) behaviors that transcend the predictable. &lt;/p&gt;</description>
    </item>
    <item>
      <title>Robots</title>
      <link>http://localhost:1313/robots/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/robots/</guid>
      <description>&lt;div class=&#34;robot-card&#34;&gt;&#xA;  &lt;div class=&#34;robot-header&#34;&gt;&#xA;    &lt;h2&gt;VICTOR&lt;/h2&gt;&#xA;    &lt;p class=&#34;robot-subtitle&#34;&gt;Vibration Controlled Tactical Operating Robot&lt;/p&gt;&#xA;  &lt;/div&gt;&#xA;  &lt;div class=&#34;robot-body&#34;&gt;&#xA;    &lt;div class=&#34;robot-img&#34;&gt;&#xA;      &lt;img src=&#34;http://localhost:1313/images/robots/VICTOR.jpg&#34; alt=&#34;VICTOR&#34;&gt;&#xA;    &lt;/div&gt;&#xA;    &lt;div class=&#34;robot-info&#34;&gt;&#xA;      &lt;p&gt;VICTOR is an inexpensive vibration-based robot that displays stochastic motion. It is used to study spontaneous self-assembly in teams of robots.&lt;/p&gt;&#xA;      &lt;div class=&#34;robot-links&#34;&gt;&#xA;        &lt;a href=&#34;http://localhost:1313/files/victor_mechanics.pdf&#34; class=&#34;robot-btn&#34;&gt;⚙️ Mechanics CAD&lt;/a&gt;&#xA;        &lt;a href=&#34;http://localhost:1313/files/victor_electronics.pdf&#34; class=&#34;robot-btn&#34;&gt;🔌 Electronics&lt;/a&gt;&#xA;        &lt;a href=&#34;https://www.youtube.com/watch?v=yXpA9rAAEUI&amp;list=PLcOkcqYHNY0A9tVPABdsOw0HBvMV7mFWK&amp;pp=0gcJCbcEOCosWNin&#34; class=&#34;robot-btn&#34; target=&#34;_blank&#34; rel=&#34;noopener&#34;&gt;▶ Video&lt;/a&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&lt;div class=&#34;robot-card&#34;&gt;&#xA;  &lt;div class=&#34;robot-header&#34;&gt;&#xA;    &lt;h2&gt;RAY&lt;/h2&gt;&#xA;    &lt;p class=&#34;robot-subtitle&#34;&gt;Robot for Aquatic Yield&lt;/p&gt;&#xA;  &lt;/div&gt;&#xA;  &lt;div class=&#34;robot-body&#34;&gt;&#xA;    &lt;div class=&#34;robot-img&#34;&gt;&#xA;      &lt;img src=&#34;http://localhost:1313/images/robots/RAY.jpg&#34; alt=&#34;RAY&#34;&gt;&#xA;    &lt;/div&gt;&#xA;    &lt;div class=&#34;robot-info&#34;&gt;&#xA;      &lt;p&gt;RAY is our robot that operates underwater. The purpose of the RAY is to study fish school dynamics and the interaction between robots and aquatic animals.&lt;/p&gt;&#xA;      &lt;div class=&#34;robot-links&#34;&gt;&#xA;        &lt;a href=&#34;http://localhost:1313/files/ray_mechanics.pdf&#34; class=&#34;robot-btn&#34;&gt;⚙️ Mechanics CAD&lt;/a&gt;&#xA;        &lt;a href=&#34;http://localhost:1313/files/ray_electronics.pdf&#34; class=&#34;robot-btn&#34;&gt;🔌 Electronics&lt;/a&gt;&#xA;        &lt;a href=&#34;https://www.youtube.com/watch?v=FljkU2jyOrQ&amp;list=PLcOkcqYHNY0BVq6tEWt6Enz5qO_J5if3k&#34; class=&#34;robot-btn&#34; target=&#34;_blank&#34; rel=&#34;noopener&#34;&gt;▶ Video&lt;/a&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/div&gt;</description>
    </item>
